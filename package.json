{
  "name": "k8s-helm-mcp",
  "version": "0.27.0",
  "description": "Production-grade Kubernetes MCP Server - Complete kubectl coverage with Infrastructure Protection, Helm support, Diagnostics, Response Caching, 267 tools, Direct Exec, OpenTelemetry",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "k8s-helm-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npx tsx scripts/build.ts",
    "build:bun": "bun build src/index.ts --outfile dist/index.js --target node --minify --external @kubernetes/client-node --external @modelcontextprotocol/sdk --external @opentelemetry/* --external express --external zod --external js-yaml",
    "build:dev": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:secure": "node --max-old-space-size=256 --experimental-permission --allow-fs-read=* --allow-child-process dist/index.js",
    "start:bun": "bun dist/index.js",
    "prepare": "husky install && npm run build",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "generate-docs": "npx tsx scripts/generate-api-docs.ts"
  },
  "keywords": [
    "kubernetes",
    "mcp",
    "kubectl",
    "kubelet",
    "k8s",
    "cluster-management",
    "devops",
    "helm",
    "diagnostics",
    "model-context-protocol"
  ],
  "author": "Meetkumar Patel <pmeet464@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meetpatel1111/k8s-helm-mcp.git"
  },
  "homepage": "https://github.com/meetpatel1111/k8s-helm-mcp#readme",
  "bugs": {
    "url": "https://github.com/meetpatel1111/k8s-helm-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.45.1",
    "@opentelemetry/instrumentation": "^0.45.1",
    "@opentelemetry/resources": "^1.18.1",
    "@opentelemetry/sdk-node": "^0.45.1",
    "@opentelemetry/sdk-trace-node": "^1.18.1",
    "@opentelemetry/semantic-conventions": "^1.18.1",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
